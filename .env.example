RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173
DTDC_USERNAME=your_dtdc_username
DTDC_PASSWORD=your_dtdc_password
REDIS_URL=redis://default:your_password@your_redis_host:6379
PORT=5000
FLASK_ENV=production

# Shipsy / DTDC Order Upload API
# Staging: https://alphademodashboardapi.shipsy.io/api/customer/integration/consignment/softdata
# Production: https://dtdcapi.shipsy.io/api/customer/integration/consignment/softdata
SHIPSY_API_URL=https://dtdcapi.shipsy.io/api/customer/integration/consignment/softdata
SHIPSY_API_KEY=your_shipsy_api_key
SHIPSY_CUSTOMER_CODE=your_customer_code

# Firm Details (Origin)
FIRM_NAME=SAGA
FIRM_PHONE=0000000000
FIRM_ADDRESS=SAGA Warehouse Address
FIRM_PINCODE=110001
FIRM_CITY=New Delhi
FIRM_STATE=Delhi
